# =============================================================================
# Ibble — Environment Variables (example)
# =============================================================================
# Copy this file to `.env` and adjust values for your machine:
#   cp .env.example .env
#
# Nuxt loads `.env` automatically. Prefer `NUXT_` / `NUXT_PUBLIC_` prefixes
# so values map to `runtimeConfig` (see nuxt.config.ts).
#
# Never commit real secrets. `.env` and `.env.*` are gitignored;
# only `*.example` files are tracked.
# =============================================================================

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NUXT_PUBLIC_APP_NAME=Ibble
NUXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# APIs
# -----------------------------------------------------------------------------
# Marketplace (stores, products, orders, …)
# Production: https://api-marketplace.ibbil.com/api
# Dev:        https://marketplace-api-ibbil-dev.dafagate.com/api
NUXT_PUBLIC_API_BASE_URL=https://api-marketplace.ibbil.com/api

# Auth service — MUST match the marketplace environment above
# Production: https://auth.ibbil.com
# Dev:        https://auth-ibbil-dev.dafagate.com
NUXT_PUBLIC_AUTH_BASE_URL=https://auth.ibbil.com

# Web API (wallets, …)
# Production: https://api-web.ibbil.com/api
NUXT_PUBLIC_WEB_API_BASE_URL=https://api-web.ibbil.com/api

# Insurance API (chip validation, policies, …)
# Production: https://api-insurance.ibbil.com/
NUXT_PUBLIC_INSURANCE_API_BASE_URL=https://api-insurance.ibbil.com/

# -----------------------------------------------------------------------------
# Contact / marketing
# -----------------------------------------------------------------------------
# International format without "+" (e.g. 9665xxxxxxxx)
NUXT_PUBLIC_WHATSAPP_NUMBER=966500000000

# -----------------------------------------------------------------------------
# HyperPay (payment widget)
# -----------------------------------------------------------------------------
NUXT_PUBLIC_HYPERPAY_WIDGET_BASE_URL=https://eu-test.oppwa.com/v1/paymentWidgets.js

# -----------------------------------------------------------------------------
# Google Maps (Places Autocomplete + Directions)
# -----------------------------------------------------------------------------
# Browser key — restrict by HTTP referrer in Google Cloud Console.
# Enable: Maps JavaScript API, Places API, Directions API
NUXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
# development | production | test
NODE_ENV=development
